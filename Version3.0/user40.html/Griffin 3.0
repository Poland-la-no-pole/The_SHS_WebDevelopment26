<!DOCTYPE html>
<html>
<head>
    <title>My Favorite Songs</title>
</head>

<body>

<h2>My Favorite Songs</h2>

<table border="1">
    <thead>
        <tr>
            <th>Song</th>
            <th>Artist</th>
            <th>Album</th>
            <th>Image</th>
        </tr>
    </thead>

    <tr>
        <td>Blinding Lights</td>
        <td>The Weeknd</td>
        <td>After Hours</td>
        <td>
            <img src="images/blinding_lights.jpg" alt="Blinding Lights Album Cover" width="100">
        </td>
    </tr>

    <tr>
        <td>Lose Yourself</td>
        <td>Eminem</td>
        <td>8 Mile</td>
        <td>
            <img src="https://upload.wikimedia.org/wikipedia/en/8/8b/Lose_Yourself.jpg" alt="Lose Yourself Cover" width="100">
        </td>
    </tr>

    <tr>
        <td>Shape of You</td>
        <td>Ed Sheeran</td>
        <td>Divide</td>
        <td>
            <img src="images/shape_of_you.jpg" alt="Shape of You Album Cover" width="100">
        </td>
    </tr>

    <tr>
        <td>Bad Guy</td>
        <td>Billie Eilish</td>
        <td>When We All Fall Asleep</td>
        <td>
            <img src="images/bad_guy.jpg" alt="Bad Guy Album Cover" width="100">
        </td>
    </tr>

    <tr>
        <td>Uptown Funk</td>
        <td>Bruno Mars</td>
        <td>Uptown Special</td>
        <td>
            <img src="images/uptown_funk.jpg" alt="Uptown Funk Album Cover" width="100">
        </td>
    </tr>

</table>

</body>
</html>